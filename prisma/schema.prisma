generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  Executive
  Manager
  Staff
}

enum InventoryStatus {
  Available
  Pending
  Sold
  Service
}

model User {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  first_name    String   @db.VarChar(50)
  last_name     String   @db.VarChar(50)
  email         String   @unique @db.VarChar(255)
  password_hash String   @db.VarChar(255)
  role          UserRole
  department    String?  @db.VarChar(50)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now()) @db.Timestamp(6)

  assigned_leads Lead[]        @relation("AssignedTo")
  repair_orders  RepairOrder[] @relation("AssignedTech")

  @@map("users")
}

model Inventory {
  vin        String          @id @db.VarChar(17)
  make       String          @db.VarChar(50)
  model      String          @db.VarChar(100)
  year       Int
  status     InventoryStatus @default(Available)
  price      Decimal?        @db.Decimal(10, 2)
  mileage    Int             @default(0)
  created_at DateTime        @default(now()) @db.Timestamp(6)

  leads         Lead[]
  repair_orders RepairOrder[]

  @@map("inventory")
}

model Lead {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assigned_to    String?  @db.Uuid
  first_name     String   @db.VarChar(50)
  last_name      String   @db.VarChar(50)
  phone          String?  @db.VarChar(20)
  email          String?  @db.VarChar(255)
  lead_score     Int      @default(0)
  status         String   @default("New") @db.VarChar(50)
  interested_vin String?  @db.VarChar(17)
  created_at     DateTime @default(now()) @db.Timestamp(6)

  assignee        User?      @relation("AssignedTo", fields: [assigned_to], references: [id])
  interested_bike Inventory? @relation(fields: [interested_vin], references: [vin])
  repair_orders   RepairOrder[]

  @@map("leads")
}

model RepairOrder {
  id            Int      @id @default(autoincrement())
  customer_id   String?  @db.Uuid
  assigned_tech String?  @db.Uuid
  vin           String?  @db.VarChar(17)
  status        String   @default("Checked In") @db.VarChar(50)
  notes         String?  @db.Text
  created_at    DateTime @default(now()) @db.Timestamp(6)

  customer  Lead?      @relation(fields: [customer_id], references: [id])
  tech      User?      @relation("AssignedTech", fields: [assigned_tech], references: [id])
  inventory Inventory? @relation(fields: [vin], references: [vin])

  @@map("repair_orders")
}
